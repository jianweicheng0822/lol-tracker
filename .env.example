# =============================================================
# LoL Tracker — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# Riot Games API key — https://developer.riotgames.com
RIOT_API_KEY=RGAPI-your-key-here

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# JWT secret — any random string (min 256 bits / 32 chars)
# Generate one with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-secret

# PostgreSQL credentials (defaults work with docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lol_tracker
DB_USER=postgres
DB_PASSWORD=postgres

# CORS allowed origin (production domain; use http://localhost:5173 for local dev)
CORS_ORIGIN=https://loltracker.lol
